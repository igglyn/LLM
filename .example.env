# Example environment variables for local development.
#
# This repository keeps shared workflow structure in XML configs, while local
# machine paths and secrets should be provided via environment variables.

# ---------- Local output/artifact paths ----------
DISTILL_EXTRACT_DIR=/tmp/extracted
DISTILL_MIXED_OUTPUT=/tmp/mixed.jsonl
DISTILL_STAGE_A_OUTPUT=/tmp/stage_a.jsonl
TRAIN_ARTIFACT_DIR=/tmp/train_artifacts

# ---------- Hugging Face ----------
# Optional token for private datasets/models when using HF-backed configs.
HF_TOKEN=
# Optional local cache override.
HF_HOME=~/.cache/huggingface

# ---------- Experiment tracking (optional) ----------
WANDB_API_KEY=
WANDB_PROJECT=llm-monorepo
